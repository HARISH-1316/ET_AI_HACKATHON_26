# ── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Database ────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/isip_db?schema=public"

# ── JWT ─────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Rate Limiting ───────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Logging ─────────────────────────────────────────
LOG_LEVEL=debug
